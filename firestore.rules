rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────

    // Any signed-in user (Google or anonymous)
    function isAuthed() {
      return request.auth != null;
    }

    // Signed in with a real Google account (not anonymous)
    function isGoogleAuthed() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Owner of the trip
    // Primary check: ownerUid matches (new trips).
    // Fallback: ownerEmail matches when ownerUid hasn't been written yet (legacy trips).
    function isOwner(tripId) {
      let d = get(/databases/$(database)/documents/trips/$(tripId)).data;
      return isGoogleAuthed() && (
        d.ownerUid == request.auth.uid ||
        (d.ownerUid == null && d.ownerEmail == request.auth.token.email)
      );
    }

    // Editor of the trip (uid in allowedEditorUids array)
    function isEditor(tripId) {
      return isGoogleAuthed() &&
        request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.get('allowedEditorUids', []);
    }

    // Can write (owner or editor)
    function canWrite(tripId) {
      return isOwner(tripId) || isEditor(tripId);
    }

    // Check if the current user has been granted proxy recording rights
    // for the given principal (principalUid is the expense owner's UID).
    // Keyed by principalUid so the principal controls their own grants.
    function isAuthorizedProxyFor(tripId, principalUid) {
      let grantDoc = get(/databases/$(database)/documents/trips/$(tripId)/proxyGrants/$(principalUid));
      return grantDoc.data != null &&
             grantDoc.data.get('proxyUids', []).hasAny([request.auth.uid]);
    }

    // ── /trips collection ──────────────────────────────────────────────────
    match /trips/{tripId} {

      // Any authenticated user can read a specific trip (visitor access via secret link = knowing the tripId)
      allow get: if isAuthed();

      // Allow collection-level queries (needed for: search by ownerUid, allowedEditorUids, collaboratorKey)
      allow list: if isAuthed();

      // Creating a new trip: must be Google-authenticated and set own UID as owner
      allow create: if isGoogleAuthed() && request.resource.data.ownerUid == request.auth.uid;

      // Updating: owner only (e.g. changing title, adding editors, uploading static data)
      allow update: if isOwner(tripId);

      // Deleting: owner only
      allow delete: if isOwner(tripId);

      // ── /events ───────────────────────────────────────────────────────────
      match /events/{eventId} {
        allow read:   if isAuthed();
        allow write:  if canWrite(tripId);
      }

      // ── /bookings ─────────────────────────────────────────────────────────
      match /bookings/{bookingId} {
        allow read:   if isAuthed();
        allow write:  if canWrite(tripId);
      }

      // ── /members ──────────────────────────────────────────────────────────
      match /members/{memberId} {
        allow read:   if isAuthed();
        allow write:  if canWrite(tripId);
      }

      // ── /lists (packing / todos) ───────────────────────────────────────────
      match /lists/{listId} {
        allow read:   if isAuthed();
        allow write:  if canWrite(tripId);
      }

      // ── /journals ─────────────────────────────────────────────────────────
      match /journals/{journalId} {
        allow read:   if isAuthed();
        allow write:  if canWrite(tripId);
      }

      // ── /journalComments ──────────────────────────────────────────────────
      match /journalComments/{commentId} {
        allow read:   if isAuthed();
        allow write:  if canWrite(tripId);
      }

      // ── /memberNotes ──────────────────────────────────────────────────────
      match /memberNotes/{noteId} {
        allow read:   if isAuthed();
        allow write:  if canWrite(tripId);
      }

      // ── /notifications ────────────────────────────────────────────────────
      match /notifications/{notifId} {
        allow read:   if isAuthed();
        allow write:  if canWrite(tripId);
      }

      // ── /proxyGrants ──────────────────────────────────────────────────────
      // Keyed by principalUid. Stores proxyUids[] — who can record on behalf
      // of the principal. Only the principal (or trip owner) can write.
      match /proxyGrants/{principalUid} {
        allow read: if canWrite(tripId);
        allow write: if canWrite(tripId) &&
          (request.auth.uid == principalUid || isOwner(tripId));
      }

      // ── /expenses ─────────────────────────────────────────────────────────
      // Private expense protection:
      //   list  → allow all authenticated users (needed for onSnapshot collection query)
      //           client-side filter hides others' private expenses in the UI
      //   get   → block reading another user's private expense directly by document ID
      //   write → can only create/edit private expenses with own UID as privateOwnerUid
      //           cannot forge another user's private expense
      //   proxy → an authorized proxy (proxyGrants) may record private expenses on
      //           behalf of the principal; may only edit/delete what they recorded
      match /expenses/{expenseId} {

        // Collection query (onSnapshot): Google-authed only. Anonymous
        // visitors don't subscribe to expenses on the client (per H2
        // optimisation) and shouldn't be able to list them server-side
        // either — this is defence-in-depth in case any future client
        // code attempts a listing under anonymous auth.
        allow list: if isGoogleAuthed();

        // Single document read: Google-authed + not someone else's private
        allow get: if isGoogleAuthed() && (
          !resource.data.get('isPrivate', false) ||
          resource.data.privateOwnerUid == request.auth.uid ||
          resource.data.get('loggedByUid', null) == request.auth.uid
        );

        // Create: editor/owner; if private, must be own UID, owner, or authorized proxy
        allow create: if canWrite(tripId) && (
          !request.resource.data.get('isPrivate', false) ||
          request.resource.data.privateOwnerUid == request.auth.uid ||
          isOwner(tripId) ||
          isAuthorizedProxyFor(tripId, request.resource.data.privateOwnerUid)
        );

        // Update: editor/owner; proxy can only update what they originally logged.
        // Defense-in-depth: settlement records are state-machine-locked at the
        // server too — confirmed (or status-less legacy) records are immutable
        // from the client; only the pending→confirmed transition is permitted.
        // (The notifSentAt / proxyNotifSentAt writes happen via Admin SDK from
        // Cloud Functions, which bypass these rules.)
        // Note: regular expenses settled via Method B (no individual stamp) are
        // still defended only at the client. Adding cross-doc settlement-state
        // verification here would require expensive get() calls per write.
        allow update: if canWrite(tripId) && (
          !request.resource.data.get('isPrivate', false) ||
          request.resource.data.privateOwnerUid == request.auth.uid ||
          isOwner(tripId) ||
          (resource.data.get('loggedByUid', null) == request.auth.uid &&
           isAuthorizedProxyFor(tripId, resource.data.privateOwnerUid))
        ) && (
          resource.data.get('category', '') != 'settlement' ||
          (resource.data.get('status', '') == 'pending' &&
           request.resource.data.get('status', '') == 'confirmed')
        );

        // Delete: proxy can only delete what they originally logged
        allow delete: if canWrite(tripId) && (
          !resource.data.get('isPrivate', false) ||
          resource.data.privateOwnerUid == request.auth.uid ||
          isOwner(tripId) ||
          (resource.data.get('loggedByUid', null) == request.auth.uid &&
           isAuthorizedProxyFor(tripId, resource.data.privateOwnerUid))
        );
      }
    }

    // ── /users: per-uid onboarding + future per-user preferences ─────────
    // Each user can read / write only their own doc. Google-signed-in only.
    match /users/{uid} {
      allow read, write: if isGoogleAuthed() && request.auth.uid == uid;
    }
  }
}
